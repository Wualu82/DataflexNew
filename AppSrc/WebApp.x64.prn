37688>>>                // If from main, this is a probably a main-file lookup from a Zoom
37688>>>                WebSet pbRender of oDetailButton to False
37689>>>                Case Break
37690>>>
37690>>>            Case Else // must be nfUndefined
37690>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37690>>>
37690>>>        Case End
37690>>>
37690>>>    End_Procedure
