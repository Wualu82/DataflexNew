38302>>>        tWebNavigateData NavigateData
38302>>>        tWebNavigateData NavigateData
38302>>>        Boolean bHasRecord
38302>>>        Handle hoDD
38302>>>
38302>>>        Get Server to hoDD
38303>>>        Get GetNavigateData to NavigateData
38304>>>        Get HasRecord of hoDD to bHasRecord
38305>>>
38305>>>        // let's hide all buttons and then Show the ones we want
38305>>>        WebSet pbRender of oEditBtn to False
38306>>>        WebSet pbRender of oSaveBtn to False
38307>>>        WebSet pbRender of oCancelChangesBtn to False
38308>>>        WebSet pbRender of oDeleteBtn to False
38309>>>
38309>>>        If (NavigateData.bReadOnly) Begin
38311>>>            WebSet pbRender of oEditBtn to True
38312>>>        End
38312>>>>
38312>>>        Else Begin
38313>>>            WebSet pbRender of oSaveBtn to True
38314>>>            WebSet pbRender of oCancelChangesBtn to True
38315>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38316>>>        End
38316>>>>
38316>>>    End_Procedure
