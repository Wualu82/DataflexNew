38238>>>                Case Break
38239>>>
38239>>>            Case Else // must be nfUndefined
38239>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38239>>>
38239>>>        Case End
38239>>>
38239>>>    End_Procedure
