37871>>>>>        Get HasRecord of hoDD to bHasRecord
37872>>>>>
37872>>>>>        // let's hide all buttons and then Show the ones we want
37872>>>>>        WebSet pbRender of oEditBtn to False
37873>>>>>        WebSet pbRender of oSaveBtn to False
37874>>>>>        WebSet pbRender of oCancelChangesBtn to False
37875>>>>>        WebSet pbRender of oDeleteBtn to False
37876>>>>>
37876>>>>>        If (NavigateData.bReadOnly) Begin
37878>>>>>            WebSet pbRender of oEditBtn to True
37879>>>>>        End
37879>>>>>>
37879>>>>>        Else Begin
37880>>>>>            WebSet pbRender of oSaveBtn to True
37881>>>>>            WebSet pbRender of oCancelChangesBtn to True
37882>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37883>>>>>        End
37883>>>>>>
37883>>>>>    End_Procedure
